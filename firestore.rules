rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection - each user can only access their own data
    match /users/{userId} {
      allow read, write: if request.auth.uid == userId;

      // Subcollections
      match /{document=**} {
        allow read, write: if request.auth.uid == userId;
      }
    }
  }
}
